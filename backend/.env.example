# ClauseGuard AI — environment configuration
# Copy this file to .env and fill in your keys.

# ── Required: at least one AI provider key ─────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ── Model selection ────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=deepseek/deepseek-chat

# ── Retrieval tuning ─────────────────────────────────────────────────────────
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_CHUNKS_FOR_RETRIEVAL=5

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=clauseguard

# ── JWT (use a long random string in production) ─────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=20971520

# ── CORS (comma-separated) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ── Optional bootstrap admin (created once on startup) ───────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Admin
